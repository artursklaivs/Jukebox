# Required: your own YouTube playlist URL. Public or unlisted playlists work best.
YOUTUBE_PLAYLIST_URL=https://www.youtube.com/watch?v=_XGAw5atF-o&list=PLyevan58K1ssswfMAVNV38gl-wUhi8JlU

# Optional: command names if these tools are not on PATH.
PLAYER_COMMAND=mpv
YTDLP_COMMAND=yt-dlp

# Optional: keep as 1 to show the Chromium window for WhatsApp login/debugging.
WHATSAPP_HEADLESS=1

# Optional: set to 1 if you want requested songs to interrupt the currently playing playlist song.
INTERRUPT_ON_REQUEST=1
